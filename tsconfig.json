{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["ESNext", "DOM.Iterable", "dom"],
    "module": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowUnusedLabels": true,
    "declaration": true
  },
  "include": [ "src/*", "types/*.d.ts", "src/**/*" ],
  "exclude": [ "src/tester.ts" ]
}
